{
  "expo": {
    "name": "Streka",
    "slug": "streka",
    "scheme": "streka",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#131712",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.streka.app"
    },
    "android": {
      "package": "com.streka.app",
      "adaptiveIcon": {
        "backgroundColor": "#17C25F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 120,
          "backgroundColor": "#131712"
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-camera",
        {
          "cameraPermission": "Streka points the camera at your plate to estimate calories."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Streka reads a photo you pick to estimate calories."
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
